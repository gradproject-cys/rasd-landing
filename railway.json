{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/rasd-landing run build"
  },
  "deploy": {
    "startCommand": "npx --yes serve artifacts/rasd-landing/dist -s -l ${PORT:-3000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
